# ══════════════════════════════════════════════════════════════════════════════
# PRAXISFORGE BACKEND - ENVIRONMENT CONFIGURATION
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ══════════════════════════════════════════════════════════════════════════════

# ── PostgreSQL Database ───────────────────────────────────────────────────────
# Used by both docker-compose (for container) and the app (for connection)
POSTGRES_USER=praxisforge
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=praxisforge
POSTGRES_HOST=postgres          # Use 'localhost' when running app outside Docker
POSTGRES_PORT=5432

# Full connection URL (constructed from above, or override directly)
# For Docker internal network:
DATABASE_URL=postgresql+asyncpg://praxisforge:your_secure_password_here@postgres:5432/praxisforge
# For local development (app outside Docker):
# DATABASE_URL=postgresql+asyncpg://praxisforge:your_secure_password_here@localhost:5432/praxisforge

# ── Qdrant Vector Database ────────────────────────────────────────────────────
QDRANT_HOST=qdrant              # Use 'localhost' when running app outside Docker
QDRANT_PORT=6333                # REST API port
QDRANT_GRPC_PORT=6334           # gRPC port (optional, for high-performance clients)
QDRANT_COLLECTION=praxisforge_docs

# ── Google Gemini (LLM + Embeddings) ──────────────────────────────────────────
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001  # 3072 dimensions
GEMINI_LLM_MODEL=models/gemini-2.5-flash

# ── Groq (Fast LLM for Background Tasks) ──────────────────────────────────────
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── HuggingFace (Optional LLM Fallback) ───────────────────────────────────────
# Get your API key from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.3
HUGGINGFACE_API_BASE=https://api-inference.huggingface.co/models
HUGGINGFACE_TIMEOUT_SECONDS=45

# ── LLM Routing / Fallback Strategy ───────────────────────────────────────────
# Allowed provider values: gemini | groq | huggingface
LLM_CHAT_PRIMARY_PROVIDER=groq
LLM_CHAT_FALLBACK_PROVIDER=gemini
LLM_SEARCH_PRIMARY_PROVIDER=groq
LLM_SEARCH_FALLBACK_PROVIDER=gemini
LLM_SUMMARY_PRIMARY_PROVIDER=groq
LLM_SUMMARY_FALLBACK_PROVIDER=gemini
LLM_EXTRACTION_PRIMARY_PROVIDER=groq
LLM_EXTRACTION_FALLBACK_PROVIDER=huggingface
LLM_RETRY_ATTEMPTS=2
LLM_RETRY_BACKOFF_SECONDS=0.7
SUMMARY_CACHE_TTL_SECONDS=120
SEARCH_CACHE_TTL_SECONDS=180
HEALTH_LLM_PROBE=false

# ── Tavily (Web Search API) ───────────────────────────────────────────────────
# Get your API key from: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# ── JWT Authentication ────────────────────────────────────────────────────────
# This must match the secret used by your external auth service
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here_minimum_32_characters
JWT_ALGORITHM=HS256

# ── File Storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads            # Relative to app root, mounted as volume in Docker

# ── Application Settings ──────────────────────────────────────────────────────
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
ENVIRONMENT=development         # development | staging | production

# Reverse proxy path prefix (leave empty for direct :8000 access)
ROOT_PATH=
